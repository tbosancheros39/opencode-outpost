# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Allowed Telegram User IDs (comma-separated, from @userinfobot)
# Multiple users are supported with varying roles.
TELEGRAM_ALLOWED_USER_IDS=

# Allowed Telegram Chat IDs (comma-separated — groups/channels the bot can operate in)
TELEGRAM_ALLOWED_CHAT_IDS=

# Super User IDs (comma-separated — these users bypass role restrictions and auto-approve permissions)
TELEGRAM_SUPER_USER_IDS=

# Telegram Proxy URL (optional)
# Supports socks5://, socks4://, http://, https:// protocols
# TELEGRAM_PROXY_URL=socks5://proxy.example.com:1080

# Redis Connection (REQUIRED for BullMQ task queue and routing)
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# OpenCode API URL (optional, default: http://localhost:4096)
# OPENCODE_API_URL=http://localhost:4096

# OpenCode Server Authentication (optional)
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=

# ============================================================================
# MODEL PROVIDER CONFIGURATION (REQUIRED)
# ============================================================================
#
# OpenCode supports 75+ providers via AI SDK and Models.dev.
# The bot connects to a LOCAL OpenCode server (opencode serve --port 4096).
# The server reads provider config from ~/.opencode/opencode.json.
#
# STEP 1: Choose a provider and model
# STEP 2: Set OPENCODE_MODEL_PROVIDER and OPENCODE_MODEL_ID below
# STEP 3: Set the provider's API key (see table below)
#
# ┌─────────────────────┬──────────────────────────┬─────────────────────────────────┐
# │ Provider            │ API Key Env Var          │ Example Models                  │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ opencode-go         │ OPENCODE_API_KEY         │ glm-5, kimi-k2.5, mimo-v2-pro,  │
# │ (OpenCode service)  │ (from opencode.ai/zen)   │ minimax-m2.7, qwen3.6-plus      │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ opencode            │ OPENCODE_API_KEY         │ minimax-m2.5-free,              │
# │ (free models)       │ (from opencode.ai/zen)   │ nemotron-3-super-free           │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ anthropic           │ ANTHROPIC_API_KEY        │ claude-opus-4-5,                │
# │                     │                          │ claude-sonnet-4-5               │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ openai              │ OPENAI_API_KEY           │ gpt-5.2, gpt-5.1-codex,         │
# │                     │                          │ gpt-4o                          │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ google              │ GOOGLE_API_KEY           │ gemini-3-pro,                   │
# │                     │                          │ gemini-2.5-flash                │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ groq                │ GROQ_API_KEY             │ llama-3.3-70b,                  │
# │                     │                          │ mixtral-8x7b-32768              │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ deepseek            │ DEEPSEEK_API_KEY         │ deepseek-chat,                  │
# │                     │                          │ deepseek-reasoner               │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ together            │ TOGETHER_API_KEY         │ kimi-k2-instruct,               │
# │                     │                          │ llama-3.3-70b                   │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ openrouter          │ OPENROUTER_API_KEY       │ (many models via routing)       │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ xai                 │ XAI_API_KEY              │ grok-beta                       │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ cerebras            │ CEREBRAS_API_KEY         │ qwen-3-coder-480b               │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ huggingface         │ HUGGINGFACE_API_KEY      │ kimi-k2-instruct, glm-4.6       │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ fireworks           │ FIREWORKS_API_KEY        │ kimi-k2-instruct                │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ moonshot            │ MOONSHOT_API_KEY         │ kimi-k2                         │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ minimax             │ MINIMAX_API_KEY          │ m2.1                            │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ z-ai               │ ZAI_API_KEY              │ glm-4.7                         │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ LOCAL (Ollama)      │ (none — local)           │ llama2, qwen3, gemma3           │
# │                     │ baseURL: localhost:11434 │                                 │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ LOCAL (LM Studio)   │ (none — local)           │ google/gemma-3n-e4b             │
# │                     │ baseURL: localhost:1234  │                                 │
# ├─────────────────────┼──────────────────────────┼─────────────────────────────────┤
# │ LOCAL (llama.cpp)   │ (none — local)           │ qwen3-coder:a3b                 │
# │                     │ baseURL: localhost:8080  │                                 │
# └─────────────────────┴──────────────────────────┴─────────────────────────────────┘
#
# For local models (Ollama, LM Studio, llama.cpp), no API key is needed.
# Configure baseURL in ~/.opencode/opencode.json instead.
#
# Full provider list: https://opencode.ai/docs/providers
#
OPENCODE_MODEL_PROVIDER=opencode
OPENCODE_MODEL_ID=big-pickle

# OpenCode API Key (for opencode-go / opencode providers ONLY)
# Get your key at: https://opencode.ai/zen
# NOT needed for anthropic, openai, google, groq, etc. — those use their own env vars.
OPENCODE_API_KEY=

# Provider-specific API keys (set the one matching your OPENCODE_MODEL_PROVIDER above)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# CEREBRAS_API_KEY=
# HUGGINGFACE_API_KEY=
# FIREWORKS_API_KEY=
# MOONSHOT_API_KEY=
# MINIMAX_API_KEY=
# ZAI_API_KEY=

# Bot Configuration & Limits (optional defaults shown)
# SESSIONS_LIST_LIMIT=10
# PROJECTS_LIST_LIMIT=10
# COMMANDS_LIST_LIMIT=10
# TASK_LIMIT=10

# Bot locale: UI language
# Supported locales: en, de, es, fr, ru, zh, bs
# BOT_LOCALE=en

# Maximum concurrent chat sessions (default: 3)
# MAX_CONCURRENT_CHATS=3

# Rate limiting (default: 30 messages per 60 seconds)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MESSAGES=30

# Streaming & Service Message Batching
# The number of seconds between service message batches to avoid Telegram rate limits
# Alias: TOOL_MESSAGES_INTERVAL_SEC (preferred)
# SERVICE_MESSAGES_INTERVAL_SEC=5
# TOOL_MESSAGES_INTERVAL_SEC=5

# Streaming response throttle (hardcoded constant — shown for reference only)
# These values are NOT configurable via environment variables.
# RESPONSE_STREAM_THROTTLE_MS=200
# DRAFT_THROTTLE_MS=150
# RESPONSE_STREAM_TEXT_LIMIT=3800

# Enable/disable response streaming (default: true)
# RESPONSE_STREAMING=true

# UI Display Options
# HIDE_THINKING_MESSAGES=false
# HIDE_TOOL_CALL_MESSAGES=false
# HIDE_TOOL_FILE_MESSAGES=false

# Assistant Formatting
# markdown = Telegram MarkdownV2, raw = plain text
# MESSAGE_FORMAT_MODE=markdown

# Size Limits
# Maximum file size in KB to send as document attachment (default: 100)
CODE_FILE_MAX_SIZE_KB=100

# Journal polling interval in seconds (default: 10)
# JOURNAL_POLL_INTERVAL_SEC=10

# OpenCode Watchdog — auto-restart OpenCode server on crash (default: enabled)
# OPENCODE_WATCHDOG_ENABLED=true
# OPENCODE_WATCHDOG_INTERVAL_SEC=30
# OPENCODE_WATCHDOG_MAX_RESTARTS=3

# Speech-to-Text / Voice Recognition (optional)
# Whisper-compatible endpoint. Set URL + key to enable voice message transcription.
#
# Provider examples:
#   OpenAI:  STT_API_URL=https://api.openai.com/v1
#   Groq:    STT_API_URL=https://api.groq.com/openai/v1
#   Together: STT_API_URL=https://api.together.xyz/v1
#
# STT_API_URL=
# STT_API_KEY=
# STT_MODEL=whisper-large-v3-turbo
# STT_LANGUAGE=  # ISO 639-1 code (en, de, es, fr, ru, zh, bs) — leave empty for auto-detect

# Text-to-Speech (optional)
# OpenAI-compatible TTS endpoint. Set URL + key to enable audio replies.
# Toggle per-chat with /tts command.
#
# Provider examples:
#   OpenAI:  TTS_API_URL=https://api.openai.com/v1
#   Groq:    TTS_API_URL=https://api.groq.com/openai/v1
#
# TTS_ENABLED=false
# TTS_API_URL=
# TTS_API_KEY=
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=alloy  # alloy, echo, fable, onyx, nova, shimmer

# Logging Configuration
# debug, info, warn, error
# LOG_LEVEL=info