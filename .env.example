# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Allowed Telegram User IDs (comma-separated, from @userinfobot)
# Multiple users are supported with varying roles.
TELEGRAM_ALLOWED_USER_IDS=

# Allowed Telegram Chat IDs (comma-separated — groups/channels the bot can operate in)
TELEGRAM_ALLOWED_CHAT_IDS=

# Super User IDs (comma-separated — these users bypass role restrictions and auto-approve permissions)
TELEGRAM_SUPER_USER_IDS=

# Telegram Proxy URL (optional)
# Supports socks5://, socks4://, http://, https:// protocols
# TELEGRAM_PROXY_URL=socks5://proxy.example.com:1080

# Redis Connection (REQUIRED for BullMQ task queue and routing)
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# OpenCode API URL (optional, default: http://localhost:4096)
# OPENCODE_API_URL=http://localhost:4096

# OpenCode Server Authentication (optional)
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=

# OpenCode Model Configuration (REQUIRED)
# Example: OPENCODE_MODEL_PROVIDER=openai, OPENCODE_MODEL_ID=gpt-4o
OPENCODE_MODEL_PROVIDER=opencode
OPENCODE_MODEL_ID=big-pickle

# Bot Configuration & Limits (optional defaults shown)
# SESSIONS_LIST_LIMIT=10
# PROJECTS_LIST_LIMIT=10
# COMMANDS_LIST_LIMIT=10
# TASK_LIMIT=10

# Bot locale: UI language
# Supported locales: en, de, es, fr, ru, zh, bs
# BOT_LOCALE=en

# Maximum concurrent chat sessions (default: 3)
# MAX_CONCURRENT_CHATS=3

# Rate limiting (default: 30 messages per 60 seconds)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MESSAGES=30

# Streaming & Service Message Batching
# The number of seconds between service message batches to avoid Telegram rate limits
# Alias: TOOL_MESSAGES_INTERVAL_SEC (preferred)
# SERVICE_MESSAGES_INTERVAL_SEC=5
# TOOL_MESSAGES_INTERVAL_SEC=5

# Streaming response throttle (hardcoded constant — shown for reference only)
# These values are NOT configurable via environment variables.
# RESPONSE_STREAM_THROTTLE_MS=200
# DRAFT_THROTTLE_MS=150
# RESPONSE_STREAM_TEXT_LIMIT=3800

# Enable/disable response streaming (default: true)
# RESPONSE_STREAMING=true

# UI Display Options
# HIDE_THINKING_MESSAGES=false
# HIDE_TOOL_CALL_MESSAGES=false
# HIDE_TOOL_FILE_MESSAGES=false

# Assistant Formatting
# markdown = Telegram MarkdownV2, raw = plain text
# MESSAGE_FORMAT_MODE=markdown

# Size Limits
# Maximum file size in KB to send as document attachment (default: 100)
# CODE_FILE_MAX_SIZE_KB=100

# Journal polling interval in seconds (default: 10)
# JOURNAL_POLL_INTERVAL_SEC=10

# OpenCode Watchdog — auto-restart OpenCode server on crash (default: enabled)
# OPENCODE_WATCHDOG_ENABLED=true
# OPENCODE_WATCHDOG_INTERVAL_SEC=30
# OPENCODE_WATCHDOG_MAX_RESTARTS=3

# Speech-to-Text / Voice Recognition (optional)
# Must point to a Whisper-compatible endpoint (OpenAI, Groq, Together)
# STT_API_URL=https://api.openai.com/v1
# STT_API_KEY=
# STT_MODEL=whisper-large-v3-turbo
# STT_LANGUAGE=

# Text-to-Speech (optional)
# TTS_ENABLED=false
# TTS_API_URL=
# TTS_API_KEY=
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=alloy

# Logging Configuration
# debug, info, warn, error
# LOG_LEVEL=info